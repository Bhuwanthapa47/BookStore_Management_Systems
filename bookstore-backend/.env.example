# Environment Variables Template for Production Deployment
# Copy this file and rename to .env (DO NOT commit .env to version control)

# Spring Profile
SPRING_PROFILE=prod

# Supabase Database Configuration
# Get these from your Supabase project settings > Database > Connection String
SUPABASE_DB_URL=jdbc:postgresql://db.xxxxxxxxxxxxx.supabase.co:5432/postgres
SUPABASE_DB_USER=postgres
SUPABASE_DB_PASSWORD=your-supabase-password

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-at-least-32-characters-long
JWT_EXPIRATION=86400000

# Frontend URL (for CORS)
FRONTEND_URL=https://your-frontend-domain.com

# Server Port (optional)
PORT=8080
